# ============================================================
# BookingApp Web — Production Environment (Railway)
# ============================================================

# Internal URL of the NestJS API. The browser never calls this directly —
# Next.js forwards /proxy/* to it server-side, so there are zero CORS issues.
# On Railway, use the API service's PRIVATE networking URL (no egress cost):
#   http://booking-api.railway.internal:3001
# (The public URL https://bookingapp-production-32f8.up.railway.app/api also
#  works but goes over the public internet.)
API_INTERNAL_URL="http://booking-api.railway.internal:3001"

# Optional defaults, INLINED at BUILD time — set them as Railway service
# variables so the Dockerfile build args pick them up. Only a fallback for the
# bare /book route + pre-login convenience; logged-in owners use their own
# businessId and clients use the URL slug, so these are not required.
NEXT_PUBLIC_BUSINESS_SLUG="demo-salon"
NEXT_PUBLIC_BUSINESS_ID="cmpuorgdm0000wk5rkk4e4qsk"

# NOTE: the web app does not read NEXT_PUBLIC_WEB_URL. Set it on the API
# service instead (NEXT_PUBLIC_WEB_URL=https://idowu.fyi) so confirmation /
# review / password-reset emails link back to this site.
