# ============================================================
# BookingApp Web — Production Environment (Railway)
# ============================================================

# Internal URL of the NestJS API. The browser never calls this directly —
# Next.js forwards /proxy/* to it server-side, so there are zero CORS issues.
# On Railway, use the API service's PRIVATE networking URL (no egress cost):
#   http://booking-api.railway.internal:3001
# If using the public URL, prefer the origin without /api:
#   https://bookingapp-production-32f8.up.railway.app
# The app also tolerates a trailing /api and normalizes it internally.
API_INTERNAL_URL="http://booking-api.railway.internal:3001"

# Public base URL of the NestJS API — used ONLY for WebSocket (Socket.io) connections
# from the browser. Must be the API origin with NO path suffix.
# ✅ Correct:   NEXT_PUBLIC_API_URL="https://api.pulseappointments.com"
# ❌ Wrong:     NEXT_PUBLIC_API_URL="https://api.pulseappointments.com/api/payments/webhook"
# If NEXT_PUBLIC_WS_URL is also set, that takes priority over this for WebSocket.
NEXT_PUBLIC_API_URL="https://api.pulseappointments.com"

# Optional defaults, INLINED at BUILD time — set them as Railway service
# variables so the Dockerfile build args pick them up. Only a fallback for the
# bare /book route + pre-login convenience; logged-in owners use their own
# businessId and clients use the URL slug, so these are not required.
NEXT_PUBLIC_BUSINESS_SLUG="demo-salon"
NEXT_PUBLIC_BUSINESS_ID="cmpuorgdm0000wk5rkk4e4qsk"

# Set NEXT_PUBLIC_WEB_URL on the API service for confirmation, review, and
# password-reset links. Web auth routes derive their origin from each request.

# Sentry error monitoring (optional — app works without it but errors won't be tracked).
# Set this on both the web Railway service AND locally in .env.local for dev.
# Get the DSN from: https://pulse-appointments.sentry.io → Settings → Projects → javascript-nextjs → Client Keys
NEXT_PUBLIC_SENTRY_DSN="https://...@o4511554536079360.ingest.us.sentry.io/..."

# HMAC signing secret for the booking_user display cookie (REQUIRED).
# The middleware verifies the cookie signature so an attacker cannot
# craft a booking_user cookie with role=ADMIN to reach the admin HTML.
# Generate with: openssl rand -base64 32
# Set this on the Railway web service (NOT the API service).
COOKIE_SIGN_SECRET="replace-with-openssl-rand-base64-32"
