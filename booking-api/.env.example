# ==========================================
# BookingApp Environment Configuration
# ==========================================

# 1. Database & Cache
# ------------------------------------------
DATABASE_URL="postgresql://bookingapp:bookingapp@localhost:5432/bookingapp?schema=public"
REDIS_URL="redis://localhost:6379"

# 2. Authentication (JWT)
# ------------------------------------------
# Generate strong random strings for these in production
JWT_SECRET="your-256-bit-secret-here"
JWT_REFRESH_SECRET="your-256-bit-refresh-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# 3. Payments (Stripe)
# ------------------------------------------
# Get these from dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 4. Email (Resend)
# ------------------------------------------
# Get from resend.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_VERIFIED_FROM="noreply@yourdomain.com"
# Optional local/staging safety: redirect outbound email to this inbox.
RESEND_TEST_REDIRECT=""
# Where to send internal alerts about new bookings
ADMIN_ALERT_EMAIL="your-admin@example.com"

# 5. SMS (Twilio)
# ------------------------------------------
# Get from twilio.com/console
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+15550000000"
TWILIO_API_KEY=""

# 6. System
# ------------------------------------------
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
API_INTERNAL_URL="http://localhost:3001"
CORS_ALLOWED_ORIGINS="http://localhost:3000"
UNLOCK_ALL_FEATURES=true
