generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  STAFF
  CLIENT
}

enum PlanTier {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationType {
  CONFIRMATION
  REMINDER_72H
  REMINDER_24H
  REMINDER_2H
  FOLLOW_UP
  CANCELLATION
  RESCHEDULE
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

enum PrivacyConsentType {
  TERMS
  PRIVACY_POLICY
  MARKETING
  TRACKING
}

enum DataErasureStatus {
  REQUESTED
  VERIFYING
  PROCESSING
  COMPLETED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED // not submitted
  PENDING // document uploaded, awaiting admin review
  VERIFIED // approved by admin
  REJECTED // admin declined (see verificationNote)
}

model Business {
  id                   String  @id @default(cuid())
  name                 String
  slug                 String  @unique
  email                String
  phone                String?
  timezone             String  @default("America/New_York")
  address              String?
  logoUrl              String?
  websiteUrl           String?
  instagramUrl         String?
  facebookUrl          String?
  tiktokUrl            String?
  postVisitMessage     String?
  bookingPageSettings  Json    @default("{}")
  notificationSettings Json    @default("{}")
  // Owner-defined intake/consultation questions shown at booking. Array of
  // { id, label, required }. Answers are stored per appointment (intakeAnswers).
  intakeQuestions      Json    @default("[]")
  taxRatePercent       Float   @default(0) // sales tax applied to totals/receipts (e.g. 13 = 13%)
  invoiceSeq           Int     @default(0) // per-business invoice number counter

  // Booking policies
  minNoticeMinutes          Int     @default(120)
  maxAdvanceDays            Int     @default(60)
  maxAdvanceMinutes         Int     @default(86400) // 60 days; minute-based for HH:MM policy UI
  cancellationWindowHours   Int     @default(24)
  cancellationWindowMinutes Int     @default(1440)
  requireDeposit            Boolean @default(false)
  depositPercent            Int     @default(25)
  noShowFeeCents            Int     @default(0)
  cancellationFeeCents      Int     @default(0)
  collectCardOnFile         Boolean @default(false)
  allowClientReschedule     Boolean @default(true)

  // Subscription
  plan          PlanTier  @default(FREE)
  planExpiresAt DateTime?
  suspended     Boolean   @default(false)

  // Cancellation policy text shown to clients before booking
  cancellationPolicy String @default("Appointments cancelled within 24 hours of the scheduled time may be subject to a cancellation fee.")

  // Display + charge currency for this business's prices/charges (CAD default).
  currency String @default("CAD")

  // Referral program: each business has a shareable code; new businesses that
  // apply someone's code at subscription checkout get a discount.
  referralCode String? @unique

  // Business verification (upload a registration doc → admin approves).
  verificationStatus          VerificationStatus @default(UNVERIFIED)
  verificationDocUrl          String?
  verificationGovernmentIdUrl String?
  verificationLegalName       String?
  verificationAddress         String?
  verificationPhone           String?
  verificationNote            String? // admin's note, e.g. rejection reason
  verificationSubmittedAt     DateTime?
  verifiedAt                  DateTime?
  // Anti-duplicate: set at signup when another business already has the same
  // normalized name + phone. Flags (never blocks) the account for admin review.
  suspectedDuplicateOfId      String?
  duplicateReviewedAt         DateTime?

  // Stripe Connect Express: the business's own connected account for payouts.
  stripeConnectAccountId   String?
  stripeConnectOnboarded   Boolean @default(false)

  // Tax/registration number shown on invoices (GST, HST, EIN, BN, etc.)
  taxNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  referralsMade       Referral[]                @relation("referrer")
  referralReceived    Referral?                 @relation("referred")
  googleCalendar      GoogleCalendarConnection?
  squareConnection    SquareConnection?
  staff               Staff[]
  services            Service[]
  resources           Resource[]
  invoices            Invoice[]
  locations           Location[]
  serviceCategories   ServiceCategory[]
  appointments        Appointment[]
  clients             Client[]
  messages            Message[]
  offers              Offer[]
  transactions        Transaction[]
  waitlist            WaitlistEntry[]
  reviews             Review[]
  campaigns           Campaign[]
  giftCards           GiftCard[]
  packages            Package[]
  clientPackages      ClientPackage[]
  payments            Payment[]
  refunds             Refund[]
  uploads             UploadedFile[]
  staffTasks          StaffTask[]
  serviceDues         ServiceDue[]
  followUpPolicies    FollowUpPolicy[]
  messageThreadStates MessageThreadState[]
  subscription        Subscription?
  privacyConsents     PrivacyConsent[]
  dataErasureRequests DataErasureRequest[]
  promoCodes          PromoCode[]
  membershipPlans     MembershipPlan[]
  clientMemberships   ClientMembership[]
}

model Review {
  id            String   @id @default(cuid())
  businessId    String
  appointmentId String?  @unique // one review per appointment
  staffId       String?
  clientName    String
  rating        Int // 1–5
  comment       String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, published])
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED // balance fully used
  VOID
}

model GiftCard {
  id             String         @id @default(cuid())
  businessId     String
  code           String // human-readable, unique per business
  initialCents   Int
  balanceCents   Int
  recipientName  String?
  recipientEmail String?
  purchaserName  String?
  message        String?
  status         GiftCardStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  expiresAt      DateTime?

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  redemptions GiftCardRedemption[]

  @@unique([businessId, code])
  @@index([businessId, status])
}

model GiftCardRedemption {
  id            String   @id @default(cuid())
  giftCardId    String
  amountCents   Int
  appointmentId String?
  createdAt     DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
}

enum PackageStatus {
  ACTIVE
  USED // all credits consumed
  EXPIRED
  VOID
}

// A reusable package product the owner defines, e.g. "5x Haircut — $200".
model Package {
  id         String   @id @default(cuid())
  businessId String
  name       String
  serviceId  String? // credits valid for this service; null = any service
  credits    Int // number of prepaid sessions
  priceCents Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientPackages ClientPackage[]

  @@index([businessId, active])
}

// A package issued to a specific client (snapshots name/service so editing the
// template never changes what a client already holds).
model ClientPackage {
  id               String        @id @default(cuid())
  businessId       String
  packageId        String?
  clientId         String
  name             String // snapshot
  serviceId        String? // snapshot
  creditsTotal     Int
  creditsRemaining Int
  status           PackageStatus @default(ACTIVE)
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())

  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  package     Package?            @relation(fields: [packageId], references: [id], onDelete: SetNull)
  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  redemptions PackageRedemption[]

  @@index([businessId, status])
  @@index([clientId])
}

model PackageRedemption {
  id              String   @id @default(cuid())
  clientPackageId String
  appointmentId   String?
  createdAt       DateTime @default(now())

  clientPackage ClientPackage @relation(fields: [clientPackageId], references: [id], onDelete: Cascade)

  @@index([clientPackageId])
}

enum CampaignChannel {
  EMAIL
  SMS
}

enum CampaignAudience {
  ALL // every client with a contact on file
  RECENT // visited in the last 30 days
  LAPSED // no visit in the last 60 days — win them back
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
}

model Campaign {
  id             String           @id @default(cuid())
  businessId     String
  name           String
  channel        CampaignChannel  @default(EMAIL)
  audience       CampaignAudience @default(ALL)
  subject        String? // email only
  body           String // supports {name} and {business} merge tags
  status         CampaignStatus   @default(DRAFT)
  recipientCount Int              @default(0)
  sentCount      Int              @default(0)
  createdAt      DateTime         @default(now())
  sentAt         DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONVERTED
  CANCELLED
}

model WaitlistEntry {
  id          String         @id @default(cuid())
  businessId  String
  name        String
  email       String
  phone       String?
  serviceId   String? // preferred service (optional)
  staffId     String? // preferred staff (optional)
  desiredDate DateTime? // preferred day (optional)
  notes       String?
  status      WaitlistStatus @default(WAITING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  name                   String
  phone                  String?
  role                   Role     @default(CLIENT)
  businessId             String?
  avatarUrl              String?
  emailVerified          Boolean  @default(false)
  mustResetPassword      Boolean  @default(false)
  twoFactorEnabled       Boolean  @default(false)
  twoFactorMethod        String   @default("EMAIL") // EMAIL | SMS
  twoFactorRecoveryCodes String[] @default([]) // sha256 hashes of one-time recovery codes
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business            Business?            @relation(fields: [businessId], references: [id], onDelete: SetNull)
  staff               Staff?
  loginEvents         LoginEvent[]
  otpChallenges       OtpChallenge[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  privacyConsents     PrivacyConsent[]
  dataErasureRequests DataErasureRequest[]
  refreshSessions     RefreshSession[]
  messageThreadStates MessageThreadState[]

  @@index([email])
  @@index([businessId])
}

// One row per active sign-in (device/session). Replaces the old single
// User.refreshToken column so a user can stay logged in on web AND mobile at the
// same time — logging in on one device no longer revokes the others. Each stores
// only a sha256 hash of the refresh token; rotated on refresh, pruned on expiry.
model RefreshSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PrivacyConsent {
  id         String             @id @default(cuid())
  userId     String
  businessId String?
  type       PrivacyConsentType
  granted    Boolean
  version    String
  source     String             @default("registration")
  ipAddress  String?
  createdAt  DateTime           @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([businessId, type, createdAt])
}

model DataErasureRequest {
  id          String            @id @default(cuid())
  userId      String
  businessId  String?
  status      DataErasureStatus @default(REQUESTED)
  reason      String?
  requestedAt DateTime          @default(now())
  completedAt DateTime?
  notes       String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([businessId, status])
  @@index([requestedAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  token     String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One row per successful sign-in. Used to detect logins from a new device and
// fire a security alert. deviceKey = hash of the user-agent (per-user).
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  deviceKey String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceKey])
}

// Short-lived one-time code for 2FA login step-up. Code is stored hashed.
model OtpChallenge {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  method     String    @default("EMAIL")
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Staff {
  id          String   @id @default(cuid())
  userId      String   @unique
  businessId  String
  bio         String?
  avatarUrl   String?
  active      Boolean  @default(true)
  permissions String[] @default([]) // extra access for staff: VIEW_MONEY, MANAGE_SERVICES, MANAGE_STAFF
  locationId  String? // which location this provider works at (multi-location)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location          Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffServices     StaffService[]
  availabilityRules AvailabilityRule[]
  timeOffs          TimeOff[]
  appointments      Appointment[]
  tasks             StaffTask[]

  @@index([businessId])
  @@index([locationId])
}

// Owner-assigned tasks for staff (least-privilege: a staff member only ever sees
// their own tasks). Staff are not part of the booking flow — this is how an owner
// delegates work to them.
model StaffTask {
  id          String    @id @default(cuid())
  businessId  String
  staffId     String?
  title       String
  notes       String?
  dueAt       DateTime?
  status      String    @default("OPEN") // OPEN | DONE
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([staffId])
}

// Recurring service-due tracker: the owner sets when a client's next visit is due
// (a cadence like every 8 weeks, or a one-off date). A daily scan flips it to DUE
// and raises an in-app prompt; the owner approves (client gets a rebook nudge and
// the cadence auto-advances) or reschedules/cancels.
model ServiceDue {
  id             String    @id @default(cuid())
  businessId     String
  clientId       String
  serviceId      String?
  policyId       String?
  cadenceDays    Int? // null = one-off custom date (no auto-advance)
  dueAt          DateTime
  status         String    @default("SCHEDULED") // SCHEDULED | DUE | CANCELLED
  messageSubject String?
  messageBody    String?
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service  Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  policy   FollowUpPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([clientId])
  @@index([status, dueAt])
}

// Reusable business/service-specific follow-up rules. ServiceDue snapshots the
// rendered subject/body so editing a policy never rewrites an existing follow-up.
model FollowUpPolicy {
  id         String   @id @default(cuid())
  businessId String
  serviceId  String?
  name       String
  trigger    String   @default("COMPLETED") // COMPLETED | MANUAL
  delayDays  Int
  subject    String
  body       String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  dues     ServiceDue[]

  @@index([businessId, enabled])
  @@index([serviceId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  priceType       String   @default("FLAT") // FLAT, PER_HOUR, STARTING_AT
  bufferBeforeMin Int      @default(0)
  bufferAfterMin  Int      @default(0)
  capacity        Int      @default(1) // > 1 = group/class: that many clients can book the same slot
  color           String   @default("#E9A23C")
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoryId       String?
  resourceId       String? // optional shared room/equipment this service occupies
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category         ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  resource         Resource?        @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  staffServices    StaffService[]
  appointments     Appointment[]
  serviceDues      ServiceDue[]
  followUpPolicies FollowUpPolicy[]

  @@index([businessId])
  @@index([categoryId])
  @@index([resourceId])
}

// A shared bookable asset (treatment room, chair, equipment). A service can
// require one; the same resource can't host two overlapping appointments.
model Resource {
  id         String   @id @default(cuid())
  businessId String
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([businessId])
}

// A physical location/branch. Optional — single-location businesses have none and
// behave as before. Staff are assigned to a location; appointments record theirs.
model Location {
  id         String   @id @default(cuid())
  businessId String
  name       String
  address    String?
  phone      String?
  timezone   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff        Staff[]
  appointments Appointment[]

  @@index([businessId])
}

// A standalone invoice: arbitrary line items, a per-business sequential number,
// and a lifecycle status. Tax is captured at issue time from the business rate.
model Invoice {
  id             String    @id @default(cuid())
  businessId     String
  clientId       String?
  number         Int // per-business sequence (from Business.invoiceSeq)
  status         String    @default("DRAFT") // DRAFT | SENT | PAID | VOID
  lineItems      Json      @default("[]") // [{ description, quantity, unitCents, amountCents }]
  notes          String?
  currency       String    @default("CAD")
  subtotalCents  Int       @default(0)
  taxRatePercent Float     @default(0)
  taxCents       Int       @default(0)
  totalCents     Int       @default(0)
  discountCents  Int       @default(0)  // flat discount before tax
  discountLabel  String?               // e.g. "10% loyalty discount"
  paymentTerms   String?               // e.g. "Net 30", "Due on receipt"
  poNumber       String?               // purchase order reference
  billingAddress String?               // free-text bill-to address override
  dueAt          DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([clientId])
}

model SystemError {
  id         String   @id @default(cuid())
  businessId String?  // null = platform-level error
  category   String   // PAYMENT | BOOKING | SMS | EMAIL | CALENDAR | AUTH | GENERAL
  severity   String   @default("ERROR") // WARN | ERROR | CRITICAL
  message    String
  stack      String?
  context    Json     @default("{}") // request path, userId, etc.
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([category])
  @@index([resolved])
  @@index([createdAt])
}

model ServiceCategory {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#E9A23C")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([businessId])
}

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model AvailabilityRule {
  id        String @id @default(cuid())
  staffId   String
  dayOfWeek Int // 0 = Sunday, 6 = Saturday
  startTime String // "HH:mm" in business timezone
  endTime   String // "HH:mm" in business timezone

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model TimeOff {
  id        String   @id @default(cuid())
  staffId   String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startsAt, endsAt])
}

model Client {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  email            String?
  phone            String?
  notes            String?
  tags             String[] @default([]) // owner labels, e.g. "VIP", "New", "Sensitive skin"
  birthday         String? // "MM-DD" — drives the daily birthday-greeting automation
  // Link to User account if client has registered
  userId           String?
  // Stripe Customer for saved cards (deposits / no-show auto-charge)
  stripeCustomerId String?
  // Square (per-merchant) customer + card-on-file for the same purpose
  squareCustomerId String?
  squareCardId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business            Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  messages            Message[]
  packages            ClientPackage[]
  payments            Payment[]
  serviceDues         ServiceDue[]
  messageThreadStates MessageThreadState[]
  invoices            Invoice[]
  memberships         ClientMembership[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@index([userId])
}

model Appointment {
  id                    String            @id @default(cuid())
  businessId            String
  staffId               String
  serviceId             String
  clientId              String
  startsAt              DateTime
  endsAt                DateTime
  status                AppointmentStatus @default(PENDING)
  cancelReason          String?
  depositCents          Int?
  totalPriceCents       Int               @default(0) // snapshot of all selected services at booking time
  stripePaymentIntentId String?
  // Saved card used for this booking (for no-show auto-charge, incl. card-on-file)
  stripePaymentMethodId String?
  // Square equivalents (deposit payment id + saved card id on the merchant account)
  squarePaymentId       String?
  squareCardId          String?
  notes                 String?
  googleEventId         String? // Google Calendar event id (when the business has calendar sync on)
  recurringGroupId      String? // shared id linking occurrences of a recurring series
  intakeAnswers         Json? // client's answers to the business intake questions, [{ label, answer }]
  locationId            String? // which location this appointment is at (multi-location)
  referralSource        String? // "How did you hear about us?" — e.g. Instagram, Google, Referral, Walk-in
  promoCodeId           String? // promo code applied at booking
  discountCents         Int               @default(0) // discount applied via promo code
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location         Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  promoCode        PromoCode?        @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  notificationLogs NotificationLog[]
  payments         Payment[]

  @@index([businessId])
  @@index([staffId])
  @@index([clientId])
  @@index([startsAt])
  @@index([staffId, startsAt, endsAt])
  @@index([recurringGroupId])
  @@index([locationId])
}

model NotificationLog {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  sentAt        DateTime            @default(now())
  status        NotificationStatus
  errorMessage  String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Message {
  id         String   @id @default(cuid())
  businessId String
  clientId   String
  content    String
  fromClient Boolean  @default(true)
  read       Boolean  @default(false)
  channel    String   @default("IN_APP") // IN_APP | SMS
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([businessId, clientId])
  @@index([createdAt])
}

// Per-user inbox state prevents one staff member from clearing another staff
// member's unread indicator. Legacy Message.read remains during migration.
model MessageThreadState {
  id         String    @id @default(cuid())
  businessId String
  clientId   String
  userId     String
  lastReadAt DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, clientId, userId])
  @@index([businessId, userId, archivedAt])
}

model Offer {
  id          String    @id @default(cuid())
  businessId  String
  title       String
  description String
  imageUrl    String?
  discount    String? // e.g. "20% off" or "$10 off"
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // e.g., "APPOINTMENT", "BUSINESS", "USER"
  entityId   String
  action     String // e.g., "CREATE", "UPDATE", "CANCEL"
  userId     String? // Who performed the action (if logged in)
  changes    Json? // Optional: before/after diff or metadata
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

enum TransactionType {
  SUBSCRIPTION
  COMMISSION
  PROCESSING_FEE
}

model Transaction {
  id          String          @id @default(cuid())
  businessId  String? // null if it's a global platform fee
  type        TransactionType
  amountCents Int
  currency    String          @default("USD")
  status      String          @default("COMPLETED") // COMPLETED, PENDING, FAILED
  provider    String? // e.g., "STRIPE"
  providerId  String?         @unique
  metadata    Json?
  createdAt   DateTime        @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([createdAt])
}

// SaaS subscription: the business's paid plan with Pulse, backed by a Stripe
// subscription. Business.plan is the denormalized current tier, kept in sync by
// the Stripe webhook; this row holds the billing details.
model Subscription {
  id                    String             @id @default(cuid())
  businessId            String             @unique
  stripeCustomerId      String?
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?
  // Square (platform account) SaaS-billing equivalents
  squareCustomerId      String?
  squareSubscriptionId  String?            @unique
  squarePlanVariationId String?
  plan                  PlanTier           @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

// ── Notification center ──────────────────────────────────────────────────────
enum NotificationKind {
  BOOKING_NEW
  BOOKING_UPDATE
  PAYMENT
  SYSTEM
}

// In-app notification inbox, per user (owners/staff/registered clients).
model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind @default(SYSTEM)
  title     String
  body      String?
  linkUrl   String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum DeliveryChannel {
  EMAIL
  SMS
  PUSH
}

// Broad delivery log for every outbound message (email/SMS/push), independent of
// appointments — complements the appointment-scoped NotificationLog.
model NotificationDelivery {
  id         String             @id @default(cuid())
  businessId String?
  userId     String?
  channel    DeliveryChannel
  recipient  String
  type       String
  dedupeKey  String?            @unique
  status     NotificationStatus
  error      String?
  createdAt  DateTime           @default(now())

  @@index([businessId, createdAt])
  @@index([createdAt])
}

model SystemMetric {
  id        String   @id @default(cuid())
  name      String // e.g., "API_LATENCY", "DB_CONNECTIONS"
  value     Float
  timestamp DateTime @default(now())

  @@index([name])
  @@index([timestamp])
}

// ── Uploaded images (logos, avatars, covers) ─────────────────────────────────
// Stored in-DB as bytea — works on ephemeral container filesystems with no extra
// infra. The bytes are wrapped behind UploadsService, so swapping to S3/R2 later
// only touches that one service (the public URL shape /uploads/:id stays the same).
enum UploadKind {
  LOGO
  AVATAR
  COVER
  OTHER
}

model UploadedFile {
  id         String     @id @default(cuid())
  businessId String
  kind       UploadKind @default(OTHER)
  mimeType   String
  sizeBytes  Int
  // Bytes live in `data` (DB storage) OR in object storage keyed by `storageKey`
  // (S3/R2). Exactly one is set, decided by whether object storage is configured.
  data       Bytes?
  storageKey String?
  createdAt  DateTime   @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ── Customer payment ledger ───────────────────────────────────────────────────
enum PaymentKind {
  DEPOSIT
  NO_SHOW_FEE
  LATE_CANCEL_FEE
  IN_PERSON
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

// First-class record of every customer charge (deposits, no-show / late-cancel
// fees, in-person Tap to Pay). One row per charge, reconciled with Stripe by
// webhook. stripePaymentIntentId is unique → webhook idempotency.
model Payment {
  id                    String        @id @default(cuid())
  businessId            String
  appointmentId         String?
  clientId              String?
  stripePaymentIntentId String?       @unique
  squarePaymentId       String?       @unique // Square payment id (idempotency + reconciliation)
  amountCents           Int
  tipCents              Int           @default(0)
  taxCents              Int           @default(0)
  currency              String        @default("usd")
  kind                  PaymentKind   @default(OTHER)
  status                PaymentStatus @default(PENDING)
  refundedCents         Int           @default(0)
  description           String?
  receiptUrl            String? // Stripe-hosted receipt, captured on payment_intent.succeeded
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  refunds     Refund[]

  @@index([businessId])
  @@index([appointmentId])
  @@index([createdAt])
}

model Refund {
  id             String       @id @default(cuid())
  businessId     String
  paymentId      String
  stripeRefundId String?      @unique
  squareRefundId String?      @unique
  amountCents    Int
  reason         String?
  status         RefundStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([paymentId])
}

enum ReferralStatus {
  PENDING // the referred business signed up / subscribed
  REWARDED // the referrer's reward has been granted
}

// Tracks a referral: one business (referrer) referred another (referred) who
// applied their code. One row per referred business (a business is referred once).
model Referral {
  id                 String         @id @default(cuid())
  code               String // the referrer's referralCode used
  referrerBusinessId String
  referredBusinessId String         @unique
  status             ReferralStatus @default(PENDING)
  createdAt          DateTime       @default(now())
  rewardedAt         DateTime?

  referrer Business @relation("referrer", fields: [referrerBusinessId], references: [id], onDelete: Cascade)
  referred Business @relation("referred", fields: [referredBusinessId], references: [id], onDelete: Cascade)

  @@index([referrerBusinessId])
}

// A business's connected Google Calendar (OAuth). One per business.
model GoogleCalendarConnection {
  id           String    @id @default(cuid())
  businessId   String    @unique
  email        String? // the connected Google account
  refreshToken String // long-lived; used to mint access tokens
  accessToken  String?
  expiresAt    DateTime?
  calendarId   String    @default("primary")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ── Promo codes ───────────────────────────────────────────────────────────────
enum DiscountType {
  PERCENT // discountValue is 0-100 (percentage)
  FLAT    // discountValue is cents
}

model PromoCode {
  id            String       @id @default(cuid())
  businessId    String
  code          String       // case-insensitive coupon code, e.g. "SUMMER20"
  discountType  DiscountType @default(PERCENT)
  discountValue Int          // percent or flat cents
  maxUsages     Int?         // null = unlimited
  usageCount    Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([businessId, code])
  @@index([businessId])
}

// ── Memberships ───────────────────────────────────────────────────────────────
enum MembershipStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model MembershipPlan {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  priceMonthly    Int      // cents per month
  active          Boolean  @default(true)
  stripeProductId String?
  stripePriceId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  memberships ClientMembership[]

  @@index([businessId])
}

model ClientMembership {
  id                   String           @id @default(cuid())
  businessId           String
  clientId             String
  planId               String
  status               MembershipStatus @default(ACTIVE)
  stripeSubscriptionId String?          @unique
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan     MembershipPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([clientId])
}

// Per-merchant Square connection (OAuth). Each business links their own Square
// account; client payments run on that account using these tokens + location.
// Mirrors GoogleCalendarConnection. Access tokens expire (~30d) and are refreshed
// via the refresh token.
model SquareConnection {
  id           String    @id @default(cuid())
  businessId   String    @unique
  merchantId   String // Square merchant id
  accessToken  String // OAuth access token (used for API calls on the merchant)
  refreshToken String // long-lived; mints new access tokens
  expiresAt    DateTime? // access-token expiry
  locationId   String? // chosen location for payments
  merchantName String?
  scopes       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
