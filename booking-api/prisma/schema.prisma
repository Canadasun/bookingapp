generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  STAFF
  CLIENT
}

enum PlanTier {
  FREE
  BASIC
  PRO
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationType {
  CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  CANCELLATION
  RESCHEDULE
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model Business {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String
  phone       String?
  timezone    String   @default("America/New_York")
  address     String?
  logoUrl     String?
  bookingPageSettings Json @default("{}")

  // Booking policies
  minNoticeMinutes      Int     @default(120)
  maxAdvanceDays        Int     @default(60)
  cancellationWindowHours Int   @default(24)
  requireDeposit        Boolean @default(false)
  depositPercent        Int     @default(25)
  noShowFeeCents        Int     @default(0)
  allowClientReschedule Boolean @default(true)

  // Subscription
  plan          PlanTier @default(FREE)
  planExpiresAt DateTime?
  suspended     Boolean  @default(false)

  // Cancellation policy text shown to clients before booking
  cancellationPolicy String @default("Appointments cancelled within 24 hours of the scheduled time may be subject to a cancellation fee.")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  staff              Staff[]
  services           Service[]
  serviceCategories  ServiceCategory[]
  appointments       Appointment[]
  clients            Client[]
  messages           Message[]
  offers             Offer[]
  transactions       Transaction[]
  waitlist           WaitlistEntry[]
  reviews            Review[]
  campaigns          Campaign[]
  giftCards          GiftCard[]
  packages           Package[]
  clientPackages     ClientPackage[]
}

model Review {
  id            String   @id @default(cuid())
  businessId    String
  appointmentId String?  @unique  // one review per appointment
  staffId       String?
  clientName    String
  rating        Int                // 1–5
  comment       String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, published])
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED  // balance fully used
  VOID
}

model GiftCard {
  id            String         @id @default(cuid())
  businessId    String
  code          String         // human-readable, unique per business
  initialCents  Int
  balanceCents  Int
  recipientName String?
  recipientEmail String?
  purchaserName String?
  message       String?
  status        GiftCardStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  expiresAt     DateTime?

  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  redemptions   GiftCardRedemption[]

  @@unique([businessId, code])
  @@index([businessId, status])
}

model GiftCardRedemption {
  id            String   @id @default(cuid())
  giftCardId    String
  amountCents   Int
  appointmentId String?
  createdAt     DateTime @default(now())

  giftCard      GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
}

enum PackageStatus {
  ACTIVE
  USED     // all credits consumed
  EXPIRED
  VOID
}

// A reusable package product the owner defines, e.g. "5x Haircut — $200".
model Package {
  id         String   @id @default(cuid())
  businessId String
  name       String
  serviceId  String?  // credits valid for this service; null = any service
  credits    Int      // number of prepaid sessions
  priceCents Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientPackages ClientPackage[]

  @@index([businessId, active])
}

// A package issued to a specific client (snapshots name/service so editing the
// template never changes what a client already holds).
model ClientPackage {
  id               String        @id @default(cuid())
  businessId       String
  packageId        String?
  clientId         String
  name             String        // snapshot
  serviceId        String?       // snapshot
  creditsTotal     Int
  creditsRemaining Int
  status           PackageStatus @default(ACTIVE)
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  package     Package?             @relation(fields: [packageId], references: [id], onDelete: SetNull)
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  redemptions PackageRedemption[]

  @@index([businessId, status])
  @@index([clientId])
}

model PackageRedemption {
  id              String   @id @default(cuid())
  clientPackageId String
  appointmentId   String?
  createdAt       DateTime @default(now())

  clientPackage ClientPackage @relation(fields: [clientPackageId], references: [id], onDelete: Cascade)

  @@index([clientPackageId])
}

enum CampaignChannel {
  EMAIL
  SMS
}

enum CampaignAudience {
  ALL      // every client with a contact on file
  RECENT   // visited in the last 30 days
  LAPSED   // no visit in the last 60 days — win them back
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
}

model Campaign {
  id             String           @id @default(cuid())
  businessId     String
  name           String
  channel        CampaignChannel  @default(EMAIL)
  audience       CampaignAudience @default(ALL)
  subject        String?          // email only
  body           String           // supports {name} and {business} merge tags
  status         CampaignStatus   @default(DRAFT)
  recipientCount Int              @default(0)
  sentCount      Int              @default(0)
  createdAt      DateTime         @default(now())
  sentAt         DateTime?

  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONVERTED
  CANCELLED
}

model WaitlistEntry {
  id          String         @id @default(cuid())
  businessId  String
  name        String
  email       String
  phone       String?
  serviceId   String?        // preferred service (optional)
  staffId     String?        // preferred staff (optional)
  desiredDate DateTime?      // preferred day (optional)
  notes       String?
  status      WaitlistStatus @default(WAITING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(CLIENT)
  businessId   String?
  refreshToken String?
  mustResetPassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  staff    Staff?

  @@index([email])
  @@index([businessId])
}

model Staff {
  id         String   @id @default(cuid())
  userId     String   @unique
  businessId String
  bio        String?
  avatarUrl  String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffServices     StaffService[]
  availabilityRules AvailabilityRule[]
  timeOffs          TimeOff[]
  appointments      Appointment[]

  @@index([businessId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  bufferBeforeMin Int      @default(0)
  bufferAfterMin  Int      @default(0)
  color           String   @default("#E9A23C")
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoryId      String?
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category        ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  staffServices   StaffService[]
  appointments    Appointment[]

  @@index([businessId])
  @@index([categoryId])
}

model ServiceCategory {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#E9A23C")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services  Service[]

  @@index([businessId])
}

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model AvailabilityRule {
  id        String @id @default(cuid())
  staffId   String
  dayOfWeek Int    // 0 = Sunday, 6 = Saturday
  startTime String // "HH:mm" in business timezone
  endTime   String // "HH:mm" in business timezone

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model TimeOff {
  id       String   @id @default(cuid())
  staffId  String
  startsAt DateTime
  endsAt   DateTime
  reason   String?
  createdAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startsAt, endsAt])
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String
  phone      String?
  notes      String?
  // Link to User account if client has registered
  userId     String?
  // Stripe Customer for saved cards (deposits / no-show auto-charge)
  stripeCustomerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  messages     Message[]
  packages     ClientPackage[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@index([userId])
}

model Appointment {
  id                   String            @id @default(cuid())
  businessId           String
  staffId              String
  serviceId            String
  clientId             String
  startsAt             DateTime
  endsAt               DateTime
  status               AppointmentStatus @default(PENDING)
  cancelReason         String?
  depositCents         Int?
  stripePaymentIntentId String?
  // Saved card used for this booking (for no-show auto-charge, incl. card-on-file)
  stripePaymentMethodId String?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff             Staff             @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service           Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  notificationLogs  NotificationLog[]

  @@index([businessId])
  @@index([staffId])
  @@index([clientId])
  @@index([startsAt])
  @@index([staffId, startsAt, endsAt])
}

model NotificationLog {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  sentAt        DateTime            @default(now())
  status        NotificationStatus
  errorMessage  String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Message {
  id         String   @id @default(cuid())
  businessId String
  clientId   String
  content    String
  fromClient Boolean  @default(true)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([businessId, clientId])
  @@index([createdAt])
}

model Offer {
  id          String    @id @default(cuid())
  businessId  String
  title       String
  description String
  imageUrl    String?
  discount    String?   // e.g. "20% off" or "$10 off"
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // e.g., "APPOINTMENT", "BUSINESS", "USER"
  entityId   String
  action     String   // e.g., "CREATE", "UPDATE", "CANCEL"
  userId     String?  // Who performed the action (if logged in)
  changes    Json?    // Optional: before/after diff or metadata
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

enum TransactionType {
  SUBSCRIPTION
  COMMISSION
  PROCESSING_FEE
}

model Transaction {
  id          String          @id @default(cuid())
  businessId  String?         // null if it's a global platform fee
  type        TransactionType
  amountCents Int
  currency    String          @default("USD")
  status      String          @default("COMPLETED") // COMPLETED, PENDING, FAILED
  provider    String?         // e.g., "STRIPE"
  providerId  String?         @unique
  metadata    Json?
  createdAt   DateTime        @default(now())

  business    Business?       @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([createdAt])
}

model SystemMetric {
  id        String   @id @default(cuid())
  name      String   // e.g., "API_LATENCY", "DB_CONNECTIONS"
  value     Float
  timestamp DateTime @default(now())

  @@index([name])
  @@index([timestamp])
}
