# ============================================================
# BookingApp API — Production Environment
# Copy this to .env.production and fill in real values
# ============================================================

# Database (Railway provides this automatically)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bookingapp?schema=public"

# Redis (Railway provides this automatically)
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET="GENERATE_64_CHAR_HEX"
JWT_REFRESH_SECRET="GENERATE_DIFFERENT_64_CHAR_HEX"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe — get from dashboard.stripe.com
# Use live keys (sk_live_...) for production
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Get from Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend — get from resend.com
# Use your verified domain: noreply@yourdomain.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_VERIFIED_FROM="noreply@yourdomain.com"
# Keep blank in production unless you intentionally want all mail redirected.
RESEND_TEST_REDIRECT=""
ADMIN_ALERT_EMAIL="your-email@example.com"

# Twilio — get from twilio.com/console
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1..."
TWILIO_API_KEY=""

# App
PORT=3001
NODE_ENV=production
NEXT_PUBLIC_WEB_URL="https://yourdomain.com"
API_INTERNAL_URL="https://your-api-domain.com"
API_PUBLIC_URL="https://your-api-domain.com"
CORS_ALLOWED_ORIGINS="https://yourdomain.com"
UNLOCK_ALL_FEATURES=true
