# ============================================================
# BookingApp API — Production Environment
# Copy this to .env.production and fill in real values
# ============================================================

# Database (Railway provides this automatically)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bookingapp?schema=public"

# Redis (Railway provides this automatically)
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET="GENERATE_64_CHAR_HEX"
JWT_REFRESH_SECRET="GENERATE_DIFFERENT_64_CHAR_HEX"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Separate keys prevent OTP/database encryption changes from depending on JWT rotation.
OTP_PEPPER="GENERATE_DIFFERENT_64_CHAR_HEX"
PROVIDER_TOKEN_ENCRYPTION_KEY="GENERATE_DIFFERENT_64_CHAR_HEX"

# Stripe — get from dashboard.stripe.com
# Use live keys (sk_live_...) for production
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Get from Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Pulse subscription billing currency. Stripe Price IDs below must support it.
STRIPE_CURRENCY="CAD"
# Recurring Price IDs created in Stripe for each paid plan
STRIPE_PRICE_BASIC="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_UNLIMITED="price_..."
# Optional referral discount coupon and referrer account credit
STRIPE_REFERRAL_COUPON=""
REFERRAL_REWARD_CENTS="1000"
# Connect webhook for payout/account events (Stripe Dashboard → Connect → Webhooks)
STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."

# Resend — get from resend.com
# Use your verified domain: noreply@yourdomain.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_VERIFIED_FROM="noreply@yourdomain.com"
# Keep blank in production unless you intentionally want all mail redirected.
RESEND_TEST_REDIRECT=""
ADMIN_ALERT_EMAIL="your-email@example.com"

# Twilio — get from twilio.com/console
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1..."
TWILIO_API_KEY=""

# App
PORT=3001
NODE_ENV=production
NEXT_PUBLIC_WEB_URL="https://www.pulseappointments.com"
API_INTERNAL_URL="http://booking-api.railway.internal:3001"
API_PUBLIC_URL="https://bookingapp-production-32f8.up.railway.app"
CORS_ALLOWED_ORIGINS="https://www.pulseappointments.com,https://pulseappointments.com"
# Google OAuth callback and web hosts must share this parent domain.
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="..."
# Calendar Sync redirect URI — register this AND the SSO URI in Google Cloud Console:
# SSO:      https://www.pulseappointments.com/api/auth/google/callback
# Calendar: https://api.pulseappointments.com/api/calendar-sync/google/callback
GOOGLE_REDIRECT_URI="https://api.pulseappointments.com/api/calendar-sync/google/callback"
OAUTH_COOKIE_DOMAIN="pulseappointments.com"

# Apple Sign In — APPLE_CLIENT_ID is the Services ID (web), not the iOS bundle ID
# Create in Apple Developer → Identifiers → Services IDs
# Register https://www.pulseappointments.com and /api/auth/apple/callback return URL
APPLE_CLIENT_ID="com.pulseappointments.web"
APPLE_MOBILE_CLIENT_ID="com.pulseappointments.app"

# Public URL for this API — required for Twilio webhook signature verification
API_PUBLIC_URL="https://api.pulseappointments.com"

UNLOCK_ALL_FEATURES=false
