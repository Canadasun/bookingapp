{
  "expo": {
    "name": "Pulse",
    "slug": "Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.canadasun.Mobile",
      "buildNumber": "23",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Pulse",
        "NSCameraUsageDescription": "Pulse uses the camera to let you scan a payment card when entering card details at checkout.",
        "NSFaceIDUsageDescription": "Pulse uses Face ID to securely sign you in and protect access to your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E9A23C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E9A23C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a30e642e-d737-4642-9e9e-e832d7676cb5"
      }
    }
  }
}
