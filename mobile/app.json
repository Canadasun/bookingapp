{
  "expo": {
    "name": "Pulse",
    "slug": "Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pulseappointments",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulseappointments.app",
      "buildNumber": "28",
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.in-app-payments": [
          "merchant.com.pulseappointments.stripe"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Pulse",
        "NSCameraUsageDescription": "Pulse uses the camera to let you scan a payment card when entering card details at checkout.",
        "NSFaceIDUsageDescription": "Pulse uses Face ID to securely sign you in and protect access to your account.",
        "NSPhotoLibraryUsageDescription": "Pulse uses your photo library to let you set your business logo and upload profile images."
      }
    },
    "android": {
      "package": "com.pulseappointments.app",
      "adaptiveIcon": {
        "backgroundColor": "#E9A23C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E9A23C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#E9A23C"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ],
      "./plugins/withNetworkSecurityConfig",
      "./plugins/withIosPinningCertificate",
      "./plugins/withPrivacyManifest",
      "expo-build-properties",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "a30e642e-d737-4642-9e9e-e832d7676cb5"
      }
    },
    "owner": "canadasun"
  }
}
